# Copy to `.env` in this folder. Never commit `.env`.
#
# ── Supabase Postgres (required for alerts, dex_tokens, signal_dispatches) ─────
# In the Supabase dashboard: Project Settings → Database → Connection string.
# Use "URI" format. For this FastAPI process, prefer:
#   • Direct: postgresql://postgres:PASSWORD@db.<project-ref>.supabase.co:5432/postgres
#   • Session pooler (IPv4-friendly): host ends with .pooler.supabase.com, port 6543
# If the password has #, @, :, /, etc., percent-encode it in the URI.
# This app reads DATABASE_URL first; if empty, SUPABASE_DATABASE_URL (some templates use that name).
#
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# SUPABASE_DATABASE_URL=
#
# Auto-injects sslmode=require for *.supabase.co and *.pooler.supabase.com when omitted.
#
# Run backend/db/schema.sql (or migrations) in the Supabase SQL Editor once before first use.
#
# Upsert Dex tokens into dex_tokens from merged feeds (default on when DB is reachable):
# CORTISOL_LOG_TOKENS_TO_DB=1
# Merged profile cache (seconds) — avoids repeated Dex merges per UI tick
# CORTISOL_PROFILE_CACHE_SECONDS=55
# CORTISOL_PROFILE_CACHE_EMPTY_SECONDS=12
#
# Pace Dex bucket requests (helps avoid HTTP 429)
# CORTISOL_DEX_LIST_PAUSE_SECONDS=1.1
# CORTISOL_DEX_FALLBACK_COOLDOWN_SECONDS=2.0
#
# token-pairs fan-out (discovery grid)
# CORTISOL_PAIR_FETCH_CONCURRENCY=6
# CORTISOL_PAIR_CACHE_SECONDS=55
# CORTISOL_PAIR_CACHE_MAX_KEYS=400
#
# Cortisol MVP pipeline (market thresholds + RugCheck Solana + alert fan-out)
# CORTISOL_MVP_MIN_LIQUIDITY_USD=25000
# CORTISOL_MVP_MIN_VOLUME_H1_USD=50000
# CORTISOL_MVP_REQUIRE_BUYS_GT_SELLS=1
# Feed UI: only show tokens that pass all MVP market gates (hide dead / zero-vol names)
# CORTISOL_FEED_MATH_PASS_ONLY=1
# CORTISOL_SAFETY_FAIL_OPEN=1           # RugCheck outages: allow Dex-only signals
# CORTISOL_SAFETY_STRICT=0               # Telegram/Discord: drop unknown/high risk when 1
# CORTISOL_RUGCHECK_API_BASE=https://api.rugcheck.xyz
# CORTISOL_SAFETY_FETCH_CONCURRENCY=4
#
# Alerts (Telegram bot + Discord webhook) — emits after /feed/with-discovery resolves
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALERT_CHAT_IDS=123456789,-1001234567890
# DISCORD_ALERT_WEBHOOK_URL=
# CORTISOL_ALERT_COOLDOWN_SECONDS=900   # Postgres signal_dispatches or in-memory TTL
# CORTISOL_ALERT_DISPATCH_ENABLED=1
#
# Helius (later v7)
# HELIUS_API_KEY=
# HELIUS_RPC_URL=
#
# Outbound webhook: Dex pair snapshots for rows in dex_tokens (polling + POST; not Dex push).
# 1000 tokens every 1s is not realistically sustainable vs Dex limits — shorten N, raise interval,
# or integrate Helius / chain streaming for prod.
# OUTBOUND_WATCHLIST_WEBHOOK_URL=https://your-receiver.example/hooks/cortisol
# OUTBOUND_WATCHLIST_WEBHOOK_SECRET=
# CORTISOL_BROADCAST_WATCHLIST_SECONDS=30
# CORTISOL_BROADCAST_WATCHLIST_TOKEN_LIMIT=250
# CORTISOL_BROADCAST_PAIR_CONCURRENCY=8